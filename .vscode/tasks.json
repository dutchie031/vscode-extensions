// See https://go.microsoft.com/fwlink/?LinkId=733558
// for the documentation about the tasks.json format
{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "watch excalidraw-sync",
			"type": "npm",
			"script": "watch",
			"problemMatcher": "$tsc-watch",
			"isBackground": true,
			"path": "${workspaceFolder}/excalidraw-sync",
			"options": {
				"cwd": "${workspaceFolder}/excalidraw-sync"
			},
			"dependsOn": [
				"build excalidraw-sync"
			],
			"presentation": {
				"reveal": "never"
			},
			"group": {
				"kind": "build"
			}
		},
		{
			"label": "build excalidraw-sync",
			"type": "npm",
			"script": "build",
			"problemMatcher": "$tsc",
			"isBackground": false,
			"path": "${workspaceFolder}/excalidraw-sync",
			"options": {
				"cwd": "${workspaceFolder}/excalidraw-sync"
			},
			"presentation": {
				"reveal": "never"
			},
			"group": {
				"kind": "build"
			}
		},
	]
}
