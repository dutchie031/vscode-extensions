// See https://go.microsoft.com/fwlink/?LinkId=733558
// for the documentation about the tasks.json format
{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "watch excalidraw-sync",
			"type": "npm",
			"script": "watch",
			"problemMatcher": "$tsc-watch",
			"isBackground": true,
			"path": "${workspaceFolder}/excalidraw-sync",
			"options": {
				"cwd": "${workspaceFolder}/excalidraw-sync"
			},
			"dependsOn": [
				"build excalidraw-sync"
			],
			"presentation": {
				"reveal": "never"
			},
			"group": {
				"kind": "build"
			}
		},
		{
			"label": "build excalidraw-sync",
			"type": "npm",
			"script": "build",
			"problemMatcher": "$tsc",
			"isBackground": false,
			"path": "${workspaceFolder}/excalidraw-sync",
			"options": {
				"cwd": "${workspaceFolder}/excalidraw-sync"
			},
			"dependsOn": [
				"build excalidraw packages"
			],
			"presentation": {
				"reveal": "never"
			},
			"group": {
				"kind": "build"
			}
		},
		{
			"label": "build excalidraw packages",
			"type": "shell",
			"command": "rm -rf packages/*/dist packages/*/types 2>/dev/null || true; yarn build:packages",
			"problemMatcher": [],
			"options": {
				"cwd": "${workspaceFolder}/excalidraw"
			},
			"presentation": {
				"reveal": "silent",
				"panel": "shared"
			},
			"group": {
				"kind": "build"
			}
		},
		{
			"label": "start excalidraw dev server",
			"type": "npm",
			"script": "start",
			"isBackground": true,
			"path": "${workspaceFolder}/excalidraw",
			"options": {
				"cwd": "${workspaceFolder}/excalidraw"
			},
			"problemMatcher": {
				"pattern": {
					"regexp": ".",
					"file": 1,
					"location": 2,
					"message": 3
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": ".",
					"endsPattern": "(Local:|ready in)"
				}
			},
			"presentation": {
				"reveal": "always",
				"panel": "dedicated"
			}
		}
	]
}
