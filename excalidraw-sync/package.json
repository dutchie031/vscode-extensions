{
  "name": "excalidraw-sync",
  "displayName": "excalidraw-sync",
  "description": "Syncing my excalidraw drawings ",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.108.1"
  },
  "categories": [
    "Other"
  ],
  "publisher": "dutchie031",
  "license": "MIT",
  "repository": {
    "url": "https://github.com/dutchie031/vscode-extensions.git"
  },
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "excalidrawSync.excalidrawEditor",
        "displayName": "Excalidraw",
        "priority": "default",
        "selector": [
           { "filenamePattern": "*.excalidraw" },
            { "filenamePattern": "*.excalidraw.json" },
            { "filenamePattern": "*.excalidraw.svg" },
            { "filenamePattern": "*.excalidraw.png" }
        ]
      }
    ],
    "commands": [
      {
        "command": "excalidraw-sync.addFolder",
        "title": "Create Folder",
        "category": "Dutchie Excalidraw Sync",
        "enablement": "view == excalidrawSyncPanel"
      },
      {
        "command": "excalidraw-sync.refreshFiles",
        "title": "Refresh Files",
        "category": "Dutchie Excalidraw Sync",
        "enablement": "view == excalidrawSyncPanel"
      },
      {
        "command": "excalidraw-sync.addExcalidrawFile",
        "title": "Create Excalidraw File",
        "category": "Dutchie Excalidraw Sync",
        "enablement": "view == excalidrawSyncPanel"
      },
      {
        "command": "excalidraw-sync.createExcalidrawFile",
        "title": "Create Excalidraw File",
        "category": "Dutchie Excalidraw Sync",
        "enablement": "view == excalidrawSyncPanel"
        
      },
      {
        "command" : "excalidraw-sync.deleteFile",
        "title": "Delete",
        "category": "Dutchie Excalidraw Sync",
        "enablement": "view == excalidrawSyncPanel"
      },
      {
        "command": "excalidraw-sync.refresh",
        "title": "Refresh",
        "category": "Dutchie Excalidraw Sync",
        "enablement": "view == excalidrawSyncPanel"
      },
      {
        "command": "excalidraw-sync.setApiKey",
        "title": "Set API Key",
        "category": "Dutchie Excalidraw Sync",
        "enablement": "view == excalidrawSyncPanel"
      },
      {
        "command": "excalidraw-sync.openExcalidrawWebview",
        "title": "Open Excalidraw Webview",
        "category": "Dutchie Excalidraw Sync"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "excalidrawSyncSidebar",
          "title": "Dutchie Excalidraw Sync",
          "icon": "media/logo.svg"
        }
      ]
    },
    "views": {
      "excalidrawSyncSidebar": [
        {
          "id": "excalidrawSyncPanel",
          "name": "Dutchie Excalidraw Sync",
          "icon": "media/logo.svg"
        }
      ]
    },
    "menus": {
      "view/item/context": [
        {
          "when": "view == excalidrawSyncPanel && viewItem == treeitem_directory",
          "command": "excalidraw-sync.addFolder",
          "group": "navigation"
        },
        {
          "when": "view == excalidrawSyncPanel && viewItem == treeitem_directory",
          "command": "excalidraw-sync.createExcalidrawFile",
          "group": "navigation"
        },
        {
          "when": "view == excalidrawSyncPanel && viewItem == treeitem_file",
          "command": "excalidraw-sync.deleteFile",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "when": "view == excalidrawSyncPanel",
          "command": "excalidraw-sync.addFolder",
          "group": "navigation"
        },
        {
          "when": "view == excalidrawSyncPanel",
          "command": "excalidraw-sync.refreshFiles",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "build-webview": "cd webview && npm install && npm run build",
    "build": "npm run build-webview && npm install && tsc -b",
    "watch": "tsc -p ./ --watch",
    "vscode:prepublish": "npm run build"
  },
  "dependencies": {
    "js-base64": "3.7.2",
    "compile": "^0.0.2"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.108.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.52.0"
  }
}
